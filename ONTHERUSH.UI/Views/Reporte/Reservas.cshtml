@model ReporteReservaVM

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reporte de Viajes - ON THE RUSH</title>
    <link rel="stylesheet" href="~/css/pages/table-base.css" />
    <link rel="stylesheet" href="~/css/pages/reports.css" />
</head>
<body>
    <div class="table-page-container">
        <!-- Header -->
        <header class="table-header">
            <div class="table-header-content">
                <a href="@Url.Action("Index", "Reporte")" class="back-button">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                    </svg>
                    <span>Volver a reportes</span>
                </a>
                <div class="table-header-info">
                    <h1 class="table-title">Reporte de Reservas</h1>
                    <p class="table-subtitle">Consulte y exporte el reporte de reservas</p>
                </div>
            </div>
        </header>

        <!-- Contenido principal -->
        <main class="table-main">
            <div class="table-container">

                <!-- Filtros -->
                <form method="get" asp-action="Reservas" asp-controller="Reporte" class="filters-section">
                    <div class="filters-grid">
                        <!-- Fecha Inicio -->
                        <div class="form-group">
                            <label for="fechaInicio" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                                </svg>
                                Fecha inicio
                            </label>
                            <input type="date"
                                   class="form-input"
                                   id="fechaInicio"
                                   name="fechaInicio"
                                   value="@Model.FechaInicio?.ToString("yyyy-MM-dd")" />
                        </div>

                        <!-- Fecha Fin -->
                        <div class="form-group">
                            <label for="fechaFin" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                                </svg>
                                Fecha fin
                            </label>
                            <input type="date"
                                   class="form-input"
                                   id="fechaFin"
                                   name="fechaFin"
                                   value="@Model.FechaFin?.ToString("yyyy-MM-dd")" />
                        </div>

                        <!-- Botones -->
                        <div class="form-actions-inline">
                            <button type="submit" class="btn btn-primary">
                                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                                </svg>
                                <span>Consultar</span>
                            </button>

                            @if (Model.Reservas != null && Model.Reservas.Any())
                            {
                                <a asp-action="ExportarReservasPdf"
                                   asp-controller="Reporte"
                                   asp-route-fechaInicio="@Model.FechaInicio?.ToString("yyyy-MM-dd")"
                                   asp-route-fechaFin="@Model.FechaFin?.ToString("yyyy-MM-dd")"
                                   class="btn btn-danger">
                                    <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V7.414A2 2 0 0015.414 6L12 2.586A2 2 0 0010.586 2H6zm5 6a1 1 0 10-2 0v3.586l-1.293-1.293a1 1 0 10-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 11.586V8z" clip-rule="evenodd" />
                                    </svg>
                                    <span>Exportar PDF</span>
                                </a>
                            }
                        </div>
                    </div>
                </form>

                <!-- Resultados -->
                @if (Model != null && Model.Reservas.Any())
                {
                    <div class="results-header">
                        <h3 class="results-title">Resultados</h3>
                        <span class="results-count">@Model.Reservas.Count() @(Model.Reservas.Count() == 1 ? "reservas encontradas" : "Reservas encontradas")</span>
                    </div>

                    <div class="table-wrapper">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Cliente</th>
                                    <th>Ruta</th>
                                    <th>Fecha de Reserva</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in Model.Reservas)
                                {
                                    <tr>
                                        <td>
                                            <span>@v.ReservaId</span>
                                        </td>
                                        <td>
                                            <div class="driver-info">
                                                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                                                </svg>
                                                <span>@v.Cliente</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span>@v.Ruta</span>
                                        </td>
                                        <td>
                                            <div class="datetime-info">
                                                <span class="date">@v.FechaReserva.ToString("dd/MM/yyyy")</span>
                                                <span class="time">@v.FechaReserva.ToString("HH:mm")</span>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="status-badge status-completado">
                                                @v.Estado
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <!-- Estado vacío -->
                    <div class="empty-state">
                        <svg class="empty-icon" width="64" height="64" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                            <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
                        </svg>
                        <h3>No hay datos para mostrar</h3>
                    </div>
                }

            </div>
        </main>

        <!-- Footer -->
        <footer class="table-footer">
            <p>© @DateTime.Now.Year ON THE RUSH · Administrador</p>
        </footer>
    </div>
</body>
</html>
