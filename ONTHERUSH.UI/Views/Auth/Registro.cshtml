@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro de usuario - ON THE RUSH</title>
    <link rel="stylesheet" href="~/css/pages/auth-registro.css" />
</head>
<body>
    <div class="registro-wrapper">
        <!-- Panel izquierdo - Branding -->
        <div class="registro-brand-panel">
            <div class="brand-content">
                <div class="brand-logo">
                    <img src="~/images/OnTheRush-removebg-preview.png" alt="On The Rush" />
                </div>
                <h1 class="brand-title">Únete a ON THE RUSH</h1>
                <p class="brand-subtitle">Crea tu cuenta y comienza a disfrutar de nuestro sistema de transporte inteligente</p>

                <!-- Footer del panel izquierdo -->
                <div class="brand-footer">
                    <p class="copyright">© @DateTime.Now.Year ON THE RUSH. Todos los derechos reservados.</p>
                    <div class="brand-links">
                        <a href="#" class="brand-link">Términos y condiciones</a>
                        <span class="separator">·</span>
                        <a href="#" class="brand-link">Política de privacidad</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel derecho - Formulario -->
        <div class="registro-form-panel">
            <div class="form-container">
                <div class="form-header">
                    <h2>Crear cuenta</h2>
                    <p>Completa el formulario para registrarte en el sistema</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                        @ViewBag.Error
                    </div>
                }

                @if (ViewBag.Exito != null)
                {
                    <div class="alert alert-success">
                        <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                        </svg>
                        @ViewBag.Exito
                    </div>
                }

                <form asp-action="Registro" asp-controller="Auth" method="post" class="registro-form">

                    <!-- Fila de 2 columnas: Nombre y Apellido -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="nombre" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                                </svg>
                                Nombre
                            </label>
                            <input type="text"
                                   id="nombre"
                                   name="nombre"
                                   class="form-input"
                                   placeholder="Tu nombre"
                                   required
                                   autocomplete="given-name" />
                        </div>

                        <div class="form-group">
                            <label for="apellido" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                                </svg>
                                Apellido
                            </label>
                            <input type="text"
                                   id="apellido"
                                   name="apellido"
                                   class="form-input"
                                   placeholder="Tu apellido"
                                   required
                                   autocomplete="family-name" />
                        </div>
                    </div>

                    <!-- Cédula -->
                    <div class="form-group">
                        <label for="cedula" class="form-label">
                            <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
                            </svg>
                            Cédula
                        </label>
                        <input type="text"
                               id="cedula"
                               name="cedula"
                               class="form-input"
                               placeholder="Número de cédula"
                               required />
                    </div>

                    <!-- Correo -->
                    <div class="form-group">
                        <label for="correo" class="form-label">
                            <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                            </svg>
                            Correo electrónico
                        </label>
                        <input type="email"
                               id="correo"
                               name="correo"
                               class="form-input"
                               placeholder="tucorreo@ejemplo.com"
                               required
                               autocomplete="email" />
                    </div>

                    <!-- Ubicación -->
                    <div class="form-group">
                        <label for="ubicacion" class="form-label">
                            <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                            </svg>
                            Ubicación
                        </label>
                        <input type="text"
                               id="ubicacion"
                               name="ubicacion"
                               class="form-input"
                               placeholder="Ej: 9.998514, -84.205716"
                               pattern="^-?\d+(\.\d+)?\s*,\s*-?\d+(\.\d+)?$" />
                        <small class="form-hint">Formato: Latitud, Longitud (opcional)</small>
                    </div>

                    <!-- Contraseña -->
                    <div class="form-group">
                        <label for="contrasena" class="form-label">
                            <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                            </svg>
                            Contraseña
                        </label>
                        <div class="password-input-wrapper">
                            <input type="password"
                                   id="contrasena"
                                   name="contrasena"
                                   class="form-input"
                                   placeholder="••••••••"
                                   required
                                   autocomplete="new-password" />
                            <button type="button" class="password-toggle" onclick="togglePassword('contrasena', this)">
                                <svg class="eye-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                                </svg>
                                <svg class="eye-slash-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" style="display: none;">
                                    <path fill-rule="evenodd" d="M3.707 2.293a1 1 0 00-1.414 1.414l14 14a1 1 0 001.414-1.414l-1.473-1.473A10.014 10.014 0 0019.542 10C18.268 5.943 14.478 3 10 3a9.958 9.958 0 00-4.512 1.074l-1.78-1.781zm4.261 4.26l1.514 1.515a2.003 2.003 0 012.45 2.45l1.514 1.514a4 4 0 00-5.478-5.478z" clip-rule="evenodd" />
                                    <path d="M12.454 16.697L9.75 13.992a4 4 0 01-3.742-3.741L2.335 6.578A9.98 9.98 0 00.458 10c1.274 4.057 5.065 7 9.542 7 .847 0 1.669-.105 2.454-.303z" />
                                </svg>
                            </button>
                        </div>
                        <div class="password-requirements">
                            <p class="requirements-title">La contraseña debe contener:</p>
                            <ul class="requirements-list">
                                <li>Al menos 6 caracteres</li>
                                <li>Una letra mayúscula</li>
                                <li>Una letra minúscula</li>
                                <li>Un número</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Confirmar contraseña -->
                    <div class="form-group">
                        <label for="confirmarContrasena" class="form-label">
                            <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                            </svg>
                            Confirmar contraseña
                        </label>
                        <div class="password-input-wrapper">
                            <input type="password"
                                   id="confirmarContrasena"
                                   name="confirmarContrasena"
                                   class="form-input"
                                   placeholder="••••••••"
                                   required
                                   autocomplete="new-password" />
                            <button type="button" class="password-toggle" onclick="togglePassword('confirmarContrasena', this)">
                                <svg class="eye-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                                </svg>
                                <svg class="eye-slash-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" style="display: none;">
                                    <path fill-rule="evenodd" d="M3.707 2.293a1 1 0 00-1.414 1.414l14 14a1 1 0 001.414-1.414l-1.473-1.473A10.014 10.014 0 0019.542 10C18.268 5.943 14.478 3 10 3a9.958 9.958 0 00-4.512 1.074l-1.78-1.781zm4.261 4.26l1.514 1.515a2.003 2.003 0 012.45 2.45l1.514 1.514a4 4 0 00-5.478-5.478z" clip-rule="evenodd" />
                                    <path d="M12.454 16.697L9.75 13.992a4 4 0 01-3.742-3.741L2.335 6.578A9.98 9.98 0 00.458 10c1.274 4.057 5.065 7 9.542 7 .847 0 1.669-.105 2.454-.303z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Botones -->
                    <div class="form-actions">
                        <button type="submit" class="btn-registro">
                            <span>Crear cuenta</span>
                            <svg class="btn-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                            </svg>
                        </button>

                        <button type="button" class="btn-volver" onclick="window.location.href='@Url.Action("Login", "Auth")'">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                            </svg>
                            <span>Volver al inicio de sesión</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const eyeIcon = button.querySelector('.eye-icon');
            const eyeSlashIcon = button.querySelector('.eye-slash-icon');
            
            if (input.type === 'password') {
                input.type = 'text';
                eyeIcon.style.display = 'none';
                eyeSlashIcon.style.display = 'block';
            } else {
                input.type = 'password';
                eyeIcon.style.display = 'block';
                eyeSlashIcon.style.display = 'none';
            }
        }
    </script>
</body>
</html>