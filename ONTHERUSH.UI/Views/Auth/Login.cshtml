@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión - ON THE RUSH</title>
    <link rel="stylesheet" href="~/css/pages/auth-login.css" />
</head>
<body>
    <div class="login-wrapper">
        <!-- Panel izquierdo - Branding -->
        <div class="login-brand-panel">
            <div class="brand-content">
                <div class="brand-logo">
                    <img src="~/images/OnTheRush-removebg-preview.png" alt="On The Rush" />
                </div>
                <h1 class="brand-title">Bienvenido a ON THE RUSH</h1>
                <p class="brand-subtitle">Sistema de gestión de transporte inteligente</p>

                <!-- Footer del panel izquierdo -->
                <div class="brand-footer">
                    <p class="copyright">© @DateTime.Now.Year ON THE RUSH. Todos los derechos reservados.</p>
                    <div class="brand-links">
                        <a href="#" class="brand-link">Términos y condiciones</a>
                        <span class="separator">·</span>
                        <a href="#" class="brand-link">Política de privacidad</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel derecho - Formulario -->
        <div class="login-form-panel">
            <div class="form-container">
                <div class="form-header">
                    <h2>Iniciar sesión</h2>
                    <p>Ingresa tus credenciales para acceder al sistema</p>
                </div>

                @if (TempData["MensajeSesion"] != null)
                {
                    <div class="alert alert-info">
                        <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                        </svg>
                        @TempData["MensajeSesion"]
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                        @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" asp-controller="Auth" method="post" class="login-form">
                    <div class="form-group">
                        <label for="correo" class="form-label">
                            <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                            </svg>
                            Correo electrónico
                        </label>
                        <input type="email"
                               id="correo"
                               name="correo"
                               class="form-input"
                               placeholder="tucorreo@ejemplo.com"
                               required
                               autocomplete="email" />
                    </div>

                    <div class="form-group">
                        <label for="contrasena" class="form-label">
                            <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
                            </svg>
                            Contraseña
                        </label>
                        <div class="password-input-wrapper" style="position: relative; display: block;">
                            <input type="password"
                                id="contrasena"
                                name="contrasena"
                                class="form-input"
                                placeholder="••••••••"
                                required
                                autocomplete="current-password"
                                style="padding-right: 50px !important;" />
                            <button type="button" 
                                class="password-toggle" 
                                onclick="togglePassword('contrasena', this)"
                                style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; padding: 8px; color: #9ca3af; z-index: 999;">
                                <svg class="eye-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
                                </svg>
                                <svg class="eye-slash-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" style="display: none;">
                                    <path fill-rule="evenodd" d="M3.707 2.293a1 1 0 00-1.414 1.414l14 14a1 1 0 001.414-1.414l-1.473-1.473A10.014 10.014 0 0019.542 10C18.268 5.943 14.478 3 10 3a9.958 9.958 0 00-4.512 1.074l-1.78-1.781zm4.261 4.26l1.514 1.515a2.003 2.003 0 012.45 2.45l1.514 1.514a4 4 0 00-5.478-5.478z" clip-rule="evenodd" />
                                    <path d="M12.454 16.697L9.75 13.992a4 4 0 01-3.742-3.741L2.335 6.578A9.98 9.98 0 00.458 10c1.274 4.057 5.065 7 9.542 7 .847 0 1.669-.105 2.454-.303z" />
                                </svg>
                            </button>
                        </div>
                    </div>
                    <div class="form-options">
                        <label class="remember-checkbox">
                            <input type="checkbox" name="recordarme" />
                            <span>Recordarme</span>
                        </label>
                        <a href="@Url.Action("RecuperarContrasena", "Auth")" class="forgot-link">
                            ¿Olvidaste tu contraseña?
                        </a>
                    </div>

                    <button type="submit" class="btn-login">
                        <span>Iniciar sesión</span>
                        <svg class="btn-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                        </svg>
                    </button>
                </form>

                <div class="form-footer">
                    <p>¿No tienes una cuenta?</p>
                    <a href="@Url.Action("Registro", "Auth")" class="register-link">
                        Regístrate aquí
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const eyeIcon = button.querySelector('.eye-icon');
            const eyeSlashIcon = button.querySelector('.eye-slash-icon');
            
            if (input.type === 'password') {
                input.type = 'text';
                eyeIcon.style.display = 'none';
                eyeSlashIcon.style.display = 'block';
            } else {
                input.type = 'password';
                eyeIcon.style.display = 'block';
                eyeSlashIcon.style.display = 'none';
            }
        }
    </script>
</body>
</html>