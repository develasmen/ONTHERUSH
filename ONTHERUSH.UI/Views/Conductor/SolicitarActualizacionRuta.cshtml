@{
    Layout = null;
    ViewData["Title"] = "Solicitar actualización de ruta";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Solicitar actualización de ruta - ON THE RUSH</title>
    <link rel="stylesheet" href="~/css/pages/form-base.css" />
</head>
<body>
    <div class="form-page-container">

        <!-- Header -->
        <header class="form-header">
            <div class="form-header-content">
                <a href="@Url.Action("PanelConductor", "Conductor")" class="back-button">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd"
                              d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
                              clip-rule="evenodd" />
                    </svg>
                    <span>Volver al panel</span>
                </a>

                <div class="form-header-info">
                    <h1 class="form-title">Solicitar actualización de ruta</h1>
                    <p class="form-subtitle">
                        Describa el cambio que desea solicitar para su ruta asignada
                    </p>
                </div>
            </div>
        </header>

        <!-- Contenido principal -->
        <main class="form-main">
            <div class="form-container">
                <div class="form-card">

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            <span>@ViewBag.Error</span>
                        </div>
                    }

                    @if (ViewBag.Info != null)
                    {
                        <div class="alert alert-warning">
                            <span>@ViewBag.Info</span>
                        </div>
                    }

                    @if (ViewBag.Exito != null)
                    {
                        <div class="alert alert-success">
                            <span>@ViewBag.Exito</span>
                        </div>
                    }

                    <form asp-action="SolicitarActualizacionRuta"
                          asp-controller="Conductor"
                          method="post">

                        <div class="form-group">
                            <label for="idRuta" class="form-label">ID de la ruta</label>
                            <input type="text"
                                   id="idRuta"
                                   name="idRuta"
                                   class="form-control"
                                   placeholder="Ingrese el ID de la ruta"
                                   required />
                        </div>

                        <div class="form-group">
                            <label for="motivo" class="form-label">Motivo de la actualización</label>
                            <textarea id="motivo"
                                      name="motivo"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Describa el cambio que desea solicitar"
                                      required></textarea>
                        </div>

                        <div class="form-group">
                            <label class="form-check-label">
                                <input type="checkbox"
                                       id="hayCambios"
                                       name="hayCambios"
                                       value="true" />
                                He realizado cambios en esta solicitud
                            </label>
                        </div>

                        <div class="form-actions">
                            <a href="@Url.Action("PanelConductor", "Conductor")"
                               class="btn btn-secondary">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-primary">
                                Enviar solicitud
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </main>

        <!-- Footer -->
        <footer class="form-footer">
            <p>© @DateTime.Now.Year ON THE RUSH · Conductor</p>
        </footer>
    </div>
</body>
</html>