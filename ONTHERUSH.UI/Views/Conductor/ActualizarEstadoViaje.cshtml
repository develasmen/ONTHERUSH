@model ONTHERUSH.Abstracciones.DTOs.ActualizarEstadoViajeViewModel

@{
    Layout = null;
    ViewData["Title"] = "Actualizar estado de viaje";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Actualizar estado de viaje - ON THE RUSH</title>
    <link rel="stylesheet" href="~/css/pages/form-base.css" />
    <link rel="stylesheet" href="~/css/pages/table-base.css" />
</head>
<body>
    <div class="form-page-container">

        <header class="form-header">
            <div class="form-header-content">
                <a href="@Url.Action("PanelConductor", "Conductor")" class="back-button">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd"
                              d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
                              clip-rule="evenodd" />
                    </svg>
                    <span>Volver al panel</span>
                </a>

                <div class="form-header-info">
                    <h1 class="form-title">Actualizar estado de viaje</h1>
                    <p class="form-subtitle">
                        Cambie el estado actual de su viaje asignado
                    </p>
                </div>
            </div>
        </header>

        <main class="form-main">
            <div class="form-container">
                <div class="form-card">

                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success" style="margin-bottom: 24px;">
                            @TempData["Mensaje"]
                        </div>
                    }

                    <div class="trip-summary" style="margin-bottom: 28px;">
                        <div class="trip-summary-card">
                            <span class="trip-summary-label">Ruta</span>
                            <span class="trip-summary-value">@Model.Ruta</span>
                        </div>

                        <div class="trip-summary-card">
                            <span class="trip-summary-label">Salida</span>
                            <span class="trip-summary-value">
                                @Model.Salida.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </div>

                        <div class="trip-summary-card">
                            <span class="trip-summary-label">Estado actual</span>
                            <span class="trip-summary-value">@Model.EstadoActual</span>
                        </div>

                        <div class="trip-summary-card">
                            <span class="trip-summary-label">Pasajeros</span>
                            <span class="trip-summary-value">@Model.Pasajeros</span>
                        </div>
                    </div>

                    <form asp-action="ActualizarEstadoViaje"
                          asp-controller="Conductor"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input asp-for="ViajeId" type="hidden" />
                        <input asp-for="Ruta" type="hidden" />
                        <input asp-for="Salida" type="hidden" />
                        <input asp-for="EstadoActual" type="hidden" />
                        <input asp-for="Pasajeros" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger validation-summary"></div>

                        <div class="form-group">
                            <label asp-for="NuevoEstado" class="form-label">
                                Nuevo estado del viaje
                            </label>

                            <select asp-for="NuevoEstado" class="form-control">
                                <option value="">Seleccione una opción</option>
                                <option value="Programado">Programado</option>
                                <option value="En camino">En camino</option>
                                <option value="Retrasado">Retrasado</option>
                                <option value="Completado">Completado</option>
                                <option value="Finalizado">Finalizado</option>
                            </select>

                            <span asp-validation-for="NuevoEstado" class="text-danger"></span>
                        </div>

                        <div class="form-actions">
                            <a href="@Url.Action("PanelConductor", "Conductor")"
                               class="btn btn-secondary">
                                Cancelar
                            </a>

                            <button type="submit" class="btn btn-primary">
                                Actualizar estado
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </main>

        <footer class="form-footer">
            <p>© @DateTime.Now.Year ON THE RUSH · Conductor</p>
        </footer>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>