@model IEnumerable<ONTHERUSH.Abstracciones.DTOs.ReporteViajeDTO>

@{
    Layout = null;
    ViewData["Title"] = "Historial de viajes";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Historial de viajes - ON THE RUSH</title>

    <link rel="stylesheet" href="~/css/pages/table-base.css" />
</head>
<body>
    <div class="table-page-container">

        <!-- Header -->
        <header class="table-header">
            <div class="table-header-content">
                <a href="@Url.Action("PanelConductor", "Conductor")" class="back-button">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd"
                              d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
                              clip-rule="evenodd" />
                    </svg>
                    <span>Volver al panel</span>
                </a>

                <div class="table-header-info">
                    <h1 class="table-title">Historial de viajes</h1>
                    <p class="table-subtitle">
                        Consulte los viajes realizados anteriormente y su estado
                    </p>
                </div>
            </div>
        </header>

        <!-- Contenido -->
        <main class="table-main">
            <div class="table-container">
                <div class="table-card">

                    @if (Model == null || !Model.Any())
                    {
                        <div class="empty-state">
                            <h3>No hay viajes registrados</h3>
                            <p>
                                Cuando finalice viajes, aparecerán aquí para consulta histórica.
                            </p>
                        </div>
                    }
                    else
                    {
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Ruta</th>
                                    <th>Conductor</th>
                                    <th>Vehículo</th>
                                    <th>Pasajeros</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var viaje in Model)
                                {
                                    <tr>
                                        <td>@viaje.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td>@viaje.Ruta</td>
                                        <td>@viaje.Conductor</td>
                                        <td>@viaje.Vehiculo</td>
                                        <td>@viaje.CantidadPasajeros</td>
                                        <td>
                                            <span class="status-badge @(viaje.Estado == "Finalizado" ? "success" : "warning")">
                                                @viaje.Estado
                                            </span>
                                        </td>
                                        <td>
                                            <a href="@Url.Action("DetalleHistorialViaje", "Conductor", new { id = viaje.ViajeId })"
                                               class="btn btn-secondary btn-sm">
                                                Ver detalle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                </div>
            </div>
        </main>

        <!-- Footer -->
        <footer class="table-footer">
            <p>© @DateTime.Now.Year ON THE RUSH · Conductor</p>
        </footer>
    </div>
</body>
</html>