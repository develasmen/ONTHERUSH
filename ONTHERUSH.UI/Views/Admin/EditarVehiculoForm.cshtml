@model ONTHERUSH.Abstracciones.DTOs.VehiculoDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar Vehículo - ON THE RUSH</title>
    <link rel="stylesheet" href="~/css/pages/table-base.css" />
    <link rel="stylesheet" href="~/css/pages/vehicles.css" />
</head>
<body>
    <div class="table-page-container">
        <!-- Header -->
        <header class="table-header">
            <div class="table-header-content">
                <a href="@Url.Action("GestionarVehiculos", "Admin")" class="back-button">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                    </svg>
                    <span>Volver a vehículos</span>
                </a>
                <div class="table-header-info">
                    <h1 class="table-title">Editar Vehículo</h1>
                    <p class="table-subtitle">Modifique los datos del vehículo @Model.Placa</p>
                </div>
            </div>
        </header>

        <!-- Contenido principal -->
        <main class="table-main">
            <div class="table-container">
                <form asp-action="EditarVehiculo" asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="VehiculoId" value="@Model.VehiculoId" />
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="Placa" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd" />
                                </svg>
                                Placa
                            </label>
                            <input type="text" 
                                   class="form-input" 
                                   id="Placa"
                                   name="Placa" 
                                   value="@Model.Placa"
                                   maxlength="20"
                                   required />
                        </div>
                        <div class="form-group">
                            <label for="Año" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                                </svg>
                                Año
                            </label>
                            <input type="number" 
                                   class="form-input" 
                                   id="Año"
                                   name="Año" 
                                   value="@Model.Año"
                                   min="1900"
                                   max="2025"
                                   required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="Marca" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                                    <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
                                </svg>
                                Marca
                            </label>
                            <input type="text" 
                                   class="form-input" 
                                   id="Marca"
                                   name="Marca" 
                                   value="@Model.Marca"
                                   maxlength="50"
                                   required />
                        </div>
                        <div class="form-group">
                            <label for="Modelo" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                                    <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm9.707 5.707a1 1 0 00-1.414-1.414L9 12.586l-1.293-1.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                </svg>
                                Modelo
                            </label>
                            <input type="text" 
                                   class="form-input" 
                                   id="Modelo"
                                   name="Modelo" 
                                   value="@Model.Modelo"
                                   maxlength="50"
                                   required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="CapacidadPasajeros" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                                </svg>
                                Capacidad de Pasajeros
                            </label>
                            <input type="number" 
                                   class="form-input" 
                                   id="CapacidadPasajeros"
                                   name="CapacidadPasajeros" 
                                   value="@Model.CapacidadPasajeros"
                                   min="1"
                                   max="50"
                                   required />
                        </div>
                        <div class="form-group">
                            <label for="Estado" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                                </svg>
                                Estado
                            </label>
                            <select class="form-input" id="Estado" name="Estado" required>
                                <option value="Activo" selected="@(Model.Estado == "Activo")">Activo</option>
                                <option value="Mantenimiento" selected="@(Model.Estado == "Mantenimiento")">Mantenimiento</option>
                                <option value="Inactivo" selected="@(Model.Estado == "Inactivo")">Inactivo</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-actions">
                        <a href="@Url.Action("GestionarVehiculos", "Admin")" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-primary">
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                            </svg>
                            <span>Guardar Cambios</span>
                        </button>
                    </div>
                </form>
            </div>
        </main>

        <!-- Footer -->
        <footer class="table-footer">
            <p>© @DateTime.Now.Year ON THE RUSH · Administrador</p>
        </footer>
    </div>
</body>
</html>