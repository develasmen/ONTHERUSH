@model IEnumerable<ONTHERUSH.AccesoADatos.Models.SolicitudCambio>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestionar Solicitudes - ON THE RUSH</title>
    <link rel="stylesheet" href="~/css/pages/table-base.css" />
    <link rel="stylesheet" href="~/css/components/modal.css" />
</head>
<body>
    <div class="table-page-container">
        <!-- Header -->
        <header class="table-header">
            <div class="table-header-content">
                <a href="@Url.Action("PanelAdministrador", "Admin")" class="back-button">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                    </svg>
                    <span>Volver al panel</span>
                </a>
                <div class="table-header-info">
                    <h1 class="table-title">Gestionar Solicitudes</h1>
                    <p class="table-subtitle">Apruebe o rechace solicitudes de cambio de información</p>
                </div>
            </div>
        </header>

        <!-- Contenido principal -->
        <main class="table-main">
            <div class="table-container">
                
                <!-- Alertas -->
                @if (TempData["Exito"] != null)
                {
                    <div class="alert alert-success">
                        <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                        </svg>
                        <span>@TempData["Exito"]</span>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                        <span>@TempData["Error"]</span>
                    </div>
                }

                @if (Model != null && Model.Any())
                {
                    <!-- Tabla de solicitudes -->
                    <div class="table-wrapper">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Usuario</th>
                                    <th>Tipo de Cambio</th>
                                    <th>Valor Actual</th>
                                    <th>Valor Nuevo</th>
                                    <th>Fecha Solicitud</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var solicitud in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="user-info">
                                                <div class="user-avatar">
                                                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                                                    </svg>
                                                </div>
                                                <div>
                                                    <div class="user-name">@solicitud.Usuario?.Nombre @solicitud.Usuario?.Apellido</div>
                                                    <div class="user-email">@solicitud.Usuario?.Email</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @if (solicitud.TipoCambio == "Email")
                                            {
                                                <span class="badge badge-blue">
                                                    <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                                                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                                        <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                                                    </svg>
                                                    Correo
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-green">
                                                    <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                                                        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                                                    </svg>
                                                    Dirección
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <div class="value-old">@solicitud.ValorActual</div>
                                        </td>
                                        <td>
                                            <div class="value-new">@solicitud.ValorNuevo</div>
                                        </td>
                                        <td>
                                            <span class="date-text">@solicitud.FechaSolicitud.ToString("dd/MM/yyyy")</span>
                                            <span class="time-text">@solicitud.FechaSolicitud.ToString("HH:mm")</span>
                                        </td>
                                        <td>
                                            <div class="action-group">
                                                <!-- Botón Aprobar -->
                                                <form asp-action="AprobarSolicitud" asp-controller="Admin" method="post" class="inline-form" 
                                                      onsubmit="return confirm('¿Está seguro de aprobar este cambio?')">
                                                    <input type="hidden" name="solicitudId" value="@solicitud.SolicitudCambioId" />
                                                    <button type="submit" class="btn-action btn-approve" title="Aprobar solicitud">
                                                        <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                        </svg>
                                                        Aprobar
                                                    </button>
                                                </form>

                                                <!-- Botón Rechazar -->
                                                <button type="button" 
                                                        class="btn-action btn-reject" 
                                                        onclick="openRejectModal(@solicitud.SolicitudCambioId)"
                                                        title="Rechazar solicitud">
                                                    <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                                                    </svg>
                                                    Rechazar
                                                </button>

                                                <!-- Modal de Rechazo (oculto) -->
                                                <div id="rejectModal@(solicitud.SolicitudCambioId)" class="modal" onclick="closeModalOnBackdrop(event, @solicitud.SolicitudCambioId)">
                                                    <div class="modal-content" onclick="event.stopPropagation()">
                                                        <div class="modal-header">
                                                            <h3 class="modal-title">
                                                                <svg width="24" height="24" viewBox="0 0 20 20" fill="currentColor">
                                                                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                                                                </svg>
                                                                Rechazar Solicitud
                                                            </h3>
                                                            <button type="button" class="modal-close" onclick="closeRejectModal(@solicitud.SolicitudCambioId)">
                                                                <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                                                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                                                                </svg>
                                                            </button>
                                                        </div>
                                                        <form asp-action="RechazarSolicitudCambio" asp-controller="Admin" method="post">
                                                            <div class="modal-body">
                                                                <input type="hidden" name="solicitudId" value="@solicitud.SolicitudCambioId" />
                                                                <div class="form-group">
                                                                    <label for="motivoRechazo@(solicitud.SolicitudCambioId)" class="form-label">
                                                                        <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                                                            <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
                                                                        </svg>
                                                                        Motivo del rechazo
                                                                    </label>
                                                                    <textarea class="form-input" 
                                                                              id="motivoRechazo@(solicitud.SolicitudCambioId)" 
                                                                              name="motivoRechazo" 
                                                                              rows="4" 
                                                                              required
                                                                              placeholder="Explique por qué se rechaza esta solicitud..."></textarea>
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" onclick="closeRejectModal(@solicitud.SolicitudCambioId)">Cancelar</button>
                                                                <button type="submit" class="btn btn-danger">
                                                                    <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                                                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                                                                    </svg>
                                                                    Rechazar Solicitud
                                                                </button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <!-- Estado vacío -->
                    <div class="empty-state">
                        <svg class="empty-icon" width="64" height="64" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                            <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd" />
                        </svg>
                        <h3>No hay solicitudes pendientes</h3>
                        <p>Todas las solicitudes han sido procesadas</p>
                    </div>
                }

            </div>
        </main>

        <!-- Footer -->
        <footer class="table-footer">
            <p>© @DateTime.Now.Year ON THE RUSH · Administrador</p>
        </footer>
    </div>

    <script>
        function openRejectModal(id) {
            document.getElementById('rejectModal' + id).classList.add('modal-open');
            document.body.style.overflow = 'hidden';
        }

        function closeRejectModal(id) {
            document.getElementById('rejectModal' + id).classList.remove('modal-open');
            document.body.style.overflow = 'auto';
        }

        function closeModalOnBackdrop(event, id) {
            if (event.target.classList.contains('modal')) {
                closeRejectModal(id);
            }
        }

        // se cierra el modal con esc
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                document.querySelectorAll('.modal.modal-open').forEach(modal => {
                    modal.classList.remove('modal-open');
                });
                document.body.style.overflow = 'auto';
            }
        });
    </script>
</body>
</html>