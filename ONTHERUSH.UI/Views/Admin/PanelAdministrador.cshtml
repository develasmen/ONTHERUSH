@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel de Administrador - ON THE RUSH</title>
    <link rel="stylesheet" href="~/css/pages/dashboard-base.css" />
</head>

<body>
    <div class="dashboard-container">
        <!-- Header del dashboard -->
        <header class="dashboard-header">
            <div class="header-content">
                <div class="header-left">
                    <div class="logo-section">
                        <img src="~/images/OnTheRush-removebg-preview.png" alt="ON THE RUSH" class="dashboard-logo" />
                    </div>
                    <div class="header-info">
                        <h1 class="dashboard-title">Panel de Administrador</h1>
                        <p class="dashboard-subtitle">Gestione usuarios, rutas y solicitudes del sistema</p>
                    </div>
                </div>
                <div class="header-right">
                    <span class="role-badge">
                        <svg class="badge-icon" width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                                  clip-rule="evenodd" />
                        </svg>
                        Administrador
                    </span>
                </div>
            </div>
        </header>

        <!-- Contenido principal -->
        <main class="dashboard-main">
            @if (TempData["MensajeBienvenidaAdmin"] != null)
            {
                <div class="alert alert-success">
                    <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd"
                              d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                              clip-rule="evenodd" />
                    </svg>
                    <span>@TempData["MensajeBienvenidaAdmin"]</span>
                </div>
            }

            <!-- Grid de tarjetas -->
            <div class="dashboard-grid">
                
                <!-- Tarjeta: Reportes de viajes -->
                <div class="dashboard-card">
                    <div class="card-icon">
                        <svg width="28" height="28" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" />
                            <path fill-rule="evenodd"
                                  d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z"
                                  clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">Reportes de viajes</h3>
                        <p class="card-description">Descargue los reportes generados por los viajes en formato PDF</p>
                    </div>
                    <div class="card-footer">
                        <a href="@Url.Action("Viajes", "Reporte")" class="btn btn-primary">
                            <span>Descargar reportes</span>
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd"
                                      d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                      clip-rule="evenodd" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Tarjeta: Gestionar usuarios -->
                <div class="dashboard-card">
                    <div class="card-icon">
                        <svg width="28" height="28" viewBox="0 0 20 20" fill="currentColor">
                            <path
                            d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                        </svg>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">Gestionar usuarios</h3>
                        <p class="card-description">Apruebe usuarios pendientes y asigne roles al sistema</p>
                    </div>
                    <div class="card-footer">
                        <a href="@Url.Action("GestionarUsuarios", "Admin")" class="btn btn-primary">
                            <span>Gestionar usuarios</span>
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd"
                                      d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                      clip-rule="evenodd" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Tarjeta: Solicitudes de usuarios -->
                <div class="dashboard-card">
                    <div class="card-icon">
                        <svg width="28" height="28" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd"
                                  d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                                  clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">Solicitudes de usuarios</h3>
                        <p class="card-description">Revise y gestione solicitudes de actualización de datos</p>
                    </div>
                    <div class="card-footer">
                        <a href="@Url.Action("GestionarSolicitudes", "Admin")" class="btn btn-primary">
                            <span>Ver solicitudes</span>
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd"
                                      d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                      clip-rule="evenodd" />
                            </svg>
                        </a>
                    </div>
                </div>

                <!--Tarjeta: Solicitudes de cambio de ruta -->

                <div class="dashboard-card">
                    <div class="card-icon">
                        <svg width="28" height="28" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd"
                                  d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                                  clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">Solicitudes de ruta</h3>
                        <p class="card-description">Revise y gestione solicitudes de cambio de ruta enviadas por
                            conductores</p>
                        </div>
                        <div class="card-footer">
                            <a href="@Url.Action("GestionarSolicitudesRuta", "Admin")" class="btn btn-primary">
                                <span>Ver solicitudes</span>
                                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd"
                                          d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                          clip-rule="evenodd" />
                                </svg>
                            </a>
                        </div>
                    </div>

                    <!-- Tarjeta: Asignar rutas -->
                    <div class="dashboard-card">
                        <div class="card-icon">
                            <svg width="28" height="28" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd"
                                      d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                                      clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="card-content">
                            <h3 class="card-title">Asignar rutas</h3>
                            <p class="card-description">Asigne rutas a conductores y gestione cambios de recorrido</p>
                        </div>
                        <div class="card-footer">
                            <a href="@Url.Action("AsignarRutas", "Admin")" class="btn btn-primary">
                                <span>Asignar rutas</span>
                                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd"
                                          d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                          clip-rule="evenodd" />
                                </svg>
                            </a>
                        </div>
                    </div>

                    <!-- Tarjeta: Ver Incidentes -->
                    <div class="dashboard-card">
                        <div class="card-icon">
                            <svg width="28" height="28" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd"
                                      d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l6.518 11.591c.75 1.334-.213 2.99-1.742 2.99H3.48c-1.53 0-2.492-1.656-1.743-2.99L8.257 3.1zM11 13a1 1 0 10-2 0 1 1 0 002 0zm-1-6a1 1 0 00-1 1v3a1 1 0 102 0V8a1 1 0 00-1-1z"
                                      clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="card-content">
                            <h3 class="card-title">Gestionar incidentes</h3>
                            <p class="card-description">
                                Revise los incidentes reportados por los conductores durante las rutas
                            </p>
                        </div>
                        <div class="card-footer">
                            <a href="@Url.Action("GestionarIncidentes", "Admin")" class="btn btn-primary">
                                <span>Ver incidentes</span>
                                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd"
                                          d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                          clip-rule="evenodd" />
                                </svg>
                            </a>
                        </div>
                    </div>


                    <!-- Tarjeta: Gestionar vehículos -->
                    <div class="dashboard-card">
                        <div class="card-icon">
                            <svg width="28" height="28" viewBox="0 0 20 20" fill="currentColor">
                                <path
                                d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                                <path
                                d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z" />
                            </svg>
                        </div>
                        <div class="card-content">
                            <h3 class="card-title">Gestionar vehículos</h3>
                            <p class="card-description">Administre los vehículos del sistema</p>
                        </div>
                        <div class="card-footer">
                            <a href="@Url.Action("GestionarVehiculos", "Admin")" class="btn btn-primary">
                                <span>Gestionar vehículos</span>
                                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd"
                                          d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                          clip-rule="evenodd" />
                                </svg>
                            </a>
                        </div>
                    </div>

                    <!-- Tarjeta: Cerrar sesión -->
                    <div class="dashboard-card">
                        <div class="card-icon">
                            <svg width="28" height="28" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd"
                                      d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z"
                                      clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="card-content">
                            <h3 class="card-title">Cerrar sesión</h3>
                            <p class="card-description">Cierre su sesión de administrador de forma segura</p>
                        </div>
                        <div class="card-footer">
                            <form asp-action="Logout" asp-controller="Auth" method="post">
                                <button type="submit" class="btn btn-danger">
                                    <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd"
                                              d="M3 3a1 1 0 00-1 1v12a1 1 0 102 0V4a1 1 0 00-1-1zm10.293 9.293a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414l-3-3a1 1 0 10-1.414 1.414L14.586 9H7a1 1 0 100 2h7.586l-1.293 1.293z"
                                              clip-rule="evenodd" />
                                    </svg>
                                    <span>Cerrar sesión</span>
                                </button>
                            </form>
                        </div>
                    </div>

                </div>
            </main>

            <!-- Footer -->
            <footer class="dashboard-footer">
                <p>© @DateTime.Now.Year ON THE RUSH · Panel de Administrador</p>
            </footer>
        </div>
    </body>

</html>