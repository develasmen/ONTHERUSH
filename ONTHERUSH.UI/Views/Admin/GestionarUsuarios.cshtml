@{
    Layout = null;
    var usuariosPendientes = ViewBag.UsuariosPendientes as IEnumerable<ONTHERUSH.AccesoADatos.Models.ApplicationUser>;
    var usuariosActivos = ViewBag.UsuariosActivos as List<(ONTHERUSH.AccesoADatos.Models.ApplicationUser usuario, IList<string> roles)>;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestionar Usuarios - ON THE RUSH</title>
    <link rel="stylesheet" href="~/css/pages/table-base.css" />
    <link rel="stylesheet" href="~/css/pages/users-tabs.css" />
</head>
<body>
    <div class="table-page-container">
        <!-- Header -->
        <header class="table-header">
            <div class="table-header-content">
                <a href="@Url.Action("PanelAdministrador", "Admin")" class="back-button">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                    </svg>
                    <span>Volver al panel</span>
                </a>
                <div class="table-header-info">
                    <h1 class="table-title">Gestionar Usuarios</h1>
                    <p class="table-subtitle">Apruebe usuarios pendientes y gestione usuarios activos del sistema</p>
                </div>
            </div>
        </header>

        <!-- Contenido principal -->
        <main class="table-main">
            <div class="table-container">

                <!-- Alertas -->
                @if (TempData["Exito"] != null)
                {
                    <div class="alert alert-success">
                        <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                        </svg>
                        <span>@TempData["Exito"]</span>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                        <span>@TempData["Error"]</span>
                    </div>
                }

                <!-- PESTAÑAS -->
                <div class="tabs-container">
                    <div class="tabs-header">
                        <button class="tab-button active" onclick="switchTab('pendientes')">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                            </svg>
                            <span>Usuarios Pendientes</span>
                            @if (usuariosPendientes != null && usuariosPendientes.Any())
                            {
                                <span class="tab-badge">@usuariosPendientes.Count()</span>
                            }
                        </button>
                        <button class="tab-button" onclick="switchTab('activos')">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />
                            </svg>
                            <span>Usuarios Activos</span>
                            @if (usuariosActivos != null && usuariosActivos.Any())
                            {
                                <span class="tab-badge">@usuariosActivos.Count()</span>
                            }
                        </button>
                    </div>

                    <!-- CONTENIDO PESTAÑA 1: USUARIOS PENDIENTES -->
                    <div id="tab-pendientes" class="tab-content active">
                        @if (usuariosPendientes != null && usuariosPendientes.Any())
                        {
                            <div class="table-wrapper">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Nombre Completo</th>
                                            <th>Cédula</th>
                                            <th>Email</th>
                                            <th>Dirección</th>
                                            <th>Fecha Registro</th>
                                            <th class="text-center">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var usuario in usuariosPendientes)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="user-info">
                                                        <div class="user-avatar">
                                                            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                                                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                                                            </svg>
                                                        </div>
                                                        <div>
                                                            <div class="user-name">@usuario.Nombre @usuario.Apellido</div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="table-badge">@usuario.Cedula</span>
                                                </td>
                                                <td>@usuario.Email</td>
                                                <td class="text-muted">@(usuario.Direccion ?? "No especificada")</td>
                                                <td>@usuario.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                                <td>
                                                    <div class="action-group">
                                                        <!-- Formulario Asignar Rol -->
                                                        <form asp-action="AsignarRol" asp-controller="Admin" method="post" class="inline-form">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="userId" value="@usuario.Id" />
                                                            <select name="rol" class="action-select" required>
                                                                <option value="">Seleccionar rol...</option>
                                                                <option value="Pasajero">Pasajero</option>
                                                                <option value="Conductor">Conductor</option>
                                                                <option value="Administrador">Administrador</option>
                                                            </select>
                                                            <button type="submit" class="btn-action btn-approve" title="Asignar rol">
                                                                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                                </svg>
                                                                Aprobar
                                                            </button>
                                                        </form>

                                                        <!-- Formulario Rechazar -->
                                                        <form asp-action="RechazarUsuario" asp-controller="Admin" method="post" class="inline-form"
                                                              onsubmit="return confirm('¿Está seguro de rechazar a @usuario.Nombre @usuario.Apellido? Esta acción eliminará la solicitud del usuario.');">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="userId" value="@usuario.Id" />
                                                            <button type="submit" class="btn-action btn-reject" title="Rechazar usuario">
                                                                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                                                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                                                                </svg>
                                                                Rechazar
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <!-- Estado vacío -->
                            <div class="empty-state">
                                <svg class="empty-icon" width="64" height="64" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                                </svg>
                                <h3>No hay usuarios pendientes</h3>
                                <p>Todos los usuarios registrados han sido procesados</p>
                            </div>
                        }
                    </div>

                    <!-- CONTENIDO PESTAÑA 2: USUARIOS ACTIVOS -->
                    <div id="tab-activos" class="tab-content">
                        @if (usuariosActivos != null && usuariosActivos.Any())
                        {
                            <div class="table-wrapper">
                                <table class="data-table">
                                    <thead>
                                        <tr>
                                            <th>Nombre Completo</th>
                                            <th>Email</th>
                                            <th>Rol</th>
                                            <th>Estado</th>
                                            <th>Fecha Registro</th>
                                            <th class="text-center">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in usuariosActivos)
                                        {
                                            var usuario = item.usuario;
                                            var roles = item.roles;
                                            var rolPrincipal = roles.FirstOrDefault() ?? "Sin rol";
                                            var estaBloqueado = usuario.LockoutEnd.HasValue && usuario.LockoutEnd.Value > DateTimeOffset.UtcNow;

                                            <tr>
                                                <td>
                                                    <div class="user-info">
                                                        <div class="user-avatar">
                                                            <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                                                                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                                                            </svg>
                                                        </div>
                                                        <div>
                                                            <div class="user-name">@usuario.Nombre @usuario.Apellido</div>
                                                            <div class="user-email">@usuario.Cedula</div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>@usuario.Email</td>
                                                <td>
                                                    @if (rolPrincipal == "Administrador")
                                                    {
                                                        <span class="role-badge role-admin">
                                                            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                                                                <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
                                                            </svg>
                                                            Administrador
                                                        </span>
                                                    }
                                                    else if (rolPrincipal == "Conductor")
                                                    {
                                                        <span class="role-badge role-conductor">
                                                            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                                                                <path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                                                                <path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z" />
                                                            </svg>
                                                            Conductor
                                                        </span>
                                                    }
                                                    else if (rolPrincipal == "Pasajero")
                                                    {
                                                        <span class="role-badge role-pasajero">
                                                            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                                                                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                                                            </svg>
                                                            Pasajero
                                                        </span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (estaBloqueado)
                                                    {
                                                        <span class="status-badge status-inactive">
                                                            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                                                                <path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524l8.367 8.368zm1.414-1.414L6.524 5.11a6 6 0 018.367 8.367zM18 10a8 8 0 11-16 0 8 8 0 0116 0z" clip-rule="evenodd" />
                                                            </svg>
                                                            Deshabilitado
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="status-badge status-active">
                                                            <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                                                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                                            </svg>
                                                            Activo
                                                        </span>
                                                    }
                                                </td>
                                                <td>@usuario.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                                <td>
                                                    <div class="action-group">
                                                        @if (estaBloqueado)
                                                        {
                                                            <!-- Botón Habilitar -->
                                                            <form asp-action="HabilitarUsuario" asp-controller="Admin" method="post"
                                                                  onsubmit="return confirm('¿Está seguro de habilitar a @usuario.Nombre @usuario.Apellido (@rolPrincipal)? El usuario podrá volver a iniciar sesión.');">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="userId" value="@usuario.Id" />
                                                                <button type="submit" class="btn-action btn-approve" title="Habilitar usuario">
                                                                    <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                                                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                                                    </svg>
                                                                    Habilitar
                                                                </button>
                                                            </form>
                                                        }
                                                        else
                                                        {
                                                            <!-- Botón Deshabilitar -->
                                                            <form asp-action="EliminarUsuarioActivo" asp-controller="Admin" method="post"
                                                                  onsubmit="return confirm('¿Está seguro de deshabilitar a @usuario.Nombre @usuario.Apellido (@rolPrincipal)? El usuario no podrá iniciar sesión pero sus datos se mantendrán en el sistema.');">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="userId" value="@usuario.Id" />
                                                                <button type="submit" class="btn-action btn-delete" title="Deshabilitar usuario">
                                                                    <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                                                        <path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524l8.367 8.368zm1.414-1.414L6.524 5.11a6 6 0 018.367 8.367zM18 10a8 8 0 11-16 0 8 8 0 0116 0z" clip-rule="evenodd" />
                                                                    </svg>
                                                                    Deshabilitar
                                                                </button>
                                                            </form>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <!-- Estado vacío -->
                            <div class="empty-state">
                                <svg class="empty-icon" width="64" height="64" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" />      
                                </svg>
                                <h3>No hay usuarios activos</h3>
                                <p>No se han aprobado usuarios todavía</p>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </main>

        <!-- Footer -->
        <footer class="table-footer">
            <p>© @DateTime.Now.Year ON THE RUSH · Administrador</p>
        </footer>
    </div>

    <script>
        function switchTab(tabName) {
            // Remover clase active de todos los botones y contenidos
            document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));

            // Agregar clase active al botón y contenido seleccionado
            event.target.closest('.tab-button').classList.add('active');
            document.getElementById('tab-' + tabName).classList.add('active');
        }
    </script>
</body>
</html>