@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Solicitar Cambios - ON THE RUSH</title>
    <link rel="stylesheet" href="~/css/pages/form-base.css" />
</head>
<body>
    <div class="form-page-container">
        <!-- Header -->
        <header class="form-header">
            <div class="form-header-content">
                <a href="@Url.Action("PanelPasajero", "Usuario")" class="back-button">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                    </svg>
                    <span>Volver al panel</span>
                </a>
                <div class="form-header-info">
                    <h1 class="form-title">Solicitar Cambios</h1>
                    <p class="form-subtitle">Solicite cambios en su correo electrónico o dirección</p>
                </div>
            </div>
        </header>

        <!-- Contenido principal -->
        <main class="form-main">
            <div class="form-container">
                
                <!-- Alerta de error general -->
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                        <div class="alert-content">
                            <p>@ViewBag.Error</p>
                        </div>
                    </div>
                }

                <!-- Alerta informativa -->
                <div class="alert alert-info">
                    <svg class="alert-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                    </svg>
                    <div class="alert-content">
                        <p><strong>Importante:</strong> Los cambios deben ser aprobados por un administrador antes de aplicarse</p>
                    </div>
                </div>

                <!-- FORMULARIO 1: Cambio de Email -->
                <div class="form-section">
                    <div class="form-section-header">
                        <svg class="section-icon" width="24" height="24" viewBox="0 0 20 20" fill="currentColor">
                            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                        </svg>
                        <h3>Cambiar Correo Electrónico</h3>
                    </div>
                    
                    <form asp-action="SolicitarCambioEmail" asp-controller="Usuario" method="post" class="form">
                        <div class="form-group">
                            <label for="nuevoEmail" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                                    <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                                </svg>
                                Nuevo correo electrónico
                            </label>
                            <input type="email"
                                   class="form-input"
                                   id="nuevoEmail"
                                   name="nuevoEmail"
                                   placeholder="nuevo-email@ejemplo.com"
                                   required
                                   autocomplete="email" />
                            <small class="form-hint">Este será su nuevo correo para iniciar sesión</small>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">
                                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" />
                                </svg>
                                <span>Solicitar Cambio de Email</span>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Separador visual -->
                <div class="form-divider"></div>

                <!-- FORMULARIO 2: Cambio de Dirección -->
                <div class="form-section">
                    <div class="form-section-header">
                        <svg class="section-icon" width="24" height="24" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                        </svg>
                        <h3>Cambiar Dirección</h3>
                    </div>
                    
                    <form asp-action="SolicitarCambioDireccion" asp-controller="Usuario" method="post" class="form">
                        <div class="form-group">
                            <label for="nuevaDireccion" class="form-label">
                                <svg class="label-icon" width="18" height="18" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
                                </svg>
                                Nueva dirección (coordenadas de Google Maps)
                            </label>
                            <input type="text"
                                   class="form-input"
                                   id="nuevaDireccion"
                                   name="nuevaDireccion"
                                   placeholder="Ej: 9.998514, -84.205716"
                                   required />
                            <small class="form-hint">Pegue las coordenadas desde Google Maps en formato: latitud, longitud</small>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="btn btn-primary">
                                <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                                    <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" />
                                </svg>
                                <span>Solicitar Cambio de Dirección</span>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Botón volver -->
                <div class="form-back-action">
                    <a href="@Url.Action("PanelPasajero", "Usuario")" class="btn btn-secondary">
                        <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                        </svg>
                        <span>Volver al Panel</span>
                    </a>
                </div>

            </div>
        </main>

        <!-- Footer -->
        <footer class="form-footer">
            <p>© @DateTime.Now.Year ON THE RUSH · Pasajero</p>
        </footer>
    </div>
</body>
</html>